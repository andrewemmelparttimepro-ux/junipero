<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox (required for Mac App Store) -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Outgoing network connections (Anthropic API, Cognee HTTP) -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Read/write access to user-selected files (export support bundles) -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Keychain access for API key storage -->
	<key>com.apple.security.keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.thrawn.console</string>
	</array>
</dict>
</plist>
